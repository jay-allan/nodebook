# Nodebook — environment variable template
#
# Copy this file to .env and fill in your values before deploying:
#   cp .env.example .env
#
# .env is gitignored — never commit it to version control.

# ── git-sync configuration ────────────────────────────────────────────────────

# SSH URL of your private GitHub fork (required)
GIT_REPO=git@github.com:your-username/your-nodebook-fork.git

# Branch to track (default: main)
GIT_BRANCH=main

# How often to pull updates from the repo, in seconds (default: 60)
SYNC_INTERVAL=60

# Absolute path to the SSH deploy key on the host (default: ./deploy_key)
# Generate with: ssh-keygen -t ed25519 -C "nodebook-deploy-key" -f ./deploy_key -N ""
SSH_KEY_PATH=./deploy_key

# ── Server configuration ──────────────────────────────────────────────────────

# Host port to expose (only used in the generic docker-compose.yml; the
# production setup uses Caddy on ports 80/443 instead)
HOST_PORT=3001
