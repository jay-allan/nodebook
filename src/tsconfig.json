{
    "compilerOptions": {
        "target": "ES2022",
        "module": "commonjs",
        "moduleResolution": "node10",
        "rootDir": ".",
        "outDir": "../dist",
        "sourceMap": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "strict": true,
        "skipLibCheck": true,
        "composite": true,
    },
    "include": [
        "**/*",
    ],
    "exclude": [
        "**/*.test.ts",
    ],
    "compileOnSave": true
}
