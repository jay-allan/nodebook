{
  "name": "nodebook",
  "version": "0.1.0",
  "description": "Lightweight file-based blog engine",
  "main": "dist/app.js",
  "scripts": {
    "dev": "BASE_PATH=. concurrently \"tsc --build --watch\" \"nodemon dist/app.js\"",
    "build": "tsc --build",
    "test": "jest src plugins --passWithNoTests",
    "lint": "eslint ./src",
    "format": "prettier --config .prettierrc.json 'src/**/*.ts' --write",
    "docs": "typedoc"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jay-allan/nodebook.git"
  },
  "author": "Jay Allan Jethwa",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/jay-allan/nodebook/issues"
  },
  "homepage": "https://github.com/jay-allan/nodebook#readme",
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/jest": "^29.5.0",
    "concurrently": "^9.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.0.0",
    "nodemon": "^3.0.0",
    "prettier": "^3.0.0",
    "ts-jest": "^29.0.0",
    "typedoc": "^0.27.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.0.0"
  },
  "dependencies": {
    "@types/ejs": "^3.1.5",
    "@types/node": "^20.10.0",
    "@types/polka": "0.5.7",
    "ejs": "^3.1.9",
    "gray-matter": "^4.0.3",
    "highlight.js": "^11.11.1",
    "marked": "^10.0.0",
    "marked-highlight": "^2.2.1",
    "marked-smartypants-lite": "^1.0.2",
    "polka": "^0.5.2",
    "semver": "^7.6.3",
    "simple-update-notifier": "^2.0.0",
    "winston": "^3.11.0"
  }
}
