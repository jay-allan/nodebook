{
    "compilerOptions": {
        "target": "ES2022",
        "module": "commonjs",
        "moduleResolution": "node10",
        "rootDir": "src",
        "outDir": "../../dist/plugins/reading-time",
        "sourceMap": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "strict": true,
        "skipLibCheck": true,
        "composite": true,
    },
    "include": [
        "src/**/*",
    ],
    "references": [
        { "path": "../../src" },
    ],
    "exclude": [
        "src/**/*.test.ts",
    ],
    "compileOnSave": true
}
